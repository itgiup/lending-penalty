{
  "name": "lending-penalty-worker",
  "main": "src/index.ts",
  "compatibility_date": "2024-01-15",
  "env": {
    "production": {
      "name": "lending-penalty-worker-prod",
      "route": "https://api.yourdomain.com/api/*"
    }
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "lending_penalty_db",
      "database_id": "YOUR_DATABASE_ID"
    }
  ]
}