{
  "name": "lending-penalty",
  "version": "2.0.0",
  "description": "Debt Management System with Hono RPC and pnpm monorepo",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "keywords": [
    "lending",
    "debt-management",
    "hono",
    "react",
    "monorepo"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "turbo": "^2.9.15",
    "prettier": "^3.4.0"
  }
}
